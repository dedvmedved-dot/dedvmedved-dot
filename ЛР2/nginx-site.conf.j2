server {
    listen {{ nginx_listen_port }};
    server_name {{ nginx_server_name }};

    root {{ nginx_document_root }};
    index index.html;

    access_log /var/log/nginx/iac-course-access.log;
    error_log  /var/log/nginx/iac-course-error.log;

    location / {
        try_files $uri $uri/ =404;
    }
}
